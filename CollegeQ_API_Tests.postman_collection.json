      ]
    },
    {
      "name": "5. Saved Colleges (Auth Required)",
      "item": [
        {
          "name": "GET Saved — ⚠ No Auth (expect 401)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/saved"
          }
        },
        {
          "name": "POST Save — ⚠ No Auth (expect 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collegeId\": \"{{id_iit_bombay}}\"\n}"
            },
            "url": "{{base_url}}/api/saved"
          }
        }
      ]
    },
    {
      "name": "6. Auth — Register",
      "item": [
        {
          "name": "POST Register — New User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "POST Register — ⚠ Duplicate Email (expect 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@collegediscovery.in\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "POST Register — ⚠ Short Password (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"short@test.com\",\n  \"password\": \"abc\"\n}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "POST Register — ⚠ Invalid Email (expect 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"not-an-email\",\n  \"password\": \"password123\"\n}"
            },
