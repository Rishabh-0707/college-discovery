# CollegeQ — Required Environment Variables
# Copy this file, rename it .env, and fill in the values.
# NEVER commit the actual .env file to git.

# ─── Database ────────────────────────────────────────────────────────────────
# Your PostgreSQL connection string (from Render, Supabase, Neon, etc.)
# Must include sslmode=require for production databases
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ─── Authentication (NextAuth v5) ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET="your-64-char-hex-secret-here"

# Your production domain — MUST match your Render URL exactly (no trailing slash)
AUTH_URL="https://your-app-name.onrender.com"

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV="production"
